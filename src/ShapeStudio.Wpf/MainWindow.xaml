<Window x:Class="ShapeStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShapeStudio - Composite Bridge Proxy"
        Width="1220"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        Background="#111827">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Padding="12"
                CornerRadius="10"
                Background="#1F2937"
                BorderBrush="#374151"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Control Panel" FontSize="18" FontWeight="SemiBold" Foreground="#E5E7EB" />
                <TextBlock Text="Scene presets" Margin="0,14,0,6" Foreground="#9CA3AF" />
                <Button Content="Load Layered Scene" Height="34" Margin="0,0,0,8" Click="LoadLayeredSceneClick" />
                <Button Content="Load Symmetry Scene" Height="34" Margin="0,0,0,8" Click="LoadSymmetrySceneClick" />
                <Separator Margin="0,8,0,8" />
                <TextBlock Text="Transformations" Margin="0,0,0,6" Foreground="#9CA3AF" />
                <Button Content="Move (+30, +15)" Height="34" Margin="0,0,0,8" Click="MoveSceneClick" />
                <Button Content="Scale x1.15" Height="34" Margin="0,0,0,8" Click="ScaleSceneClick" />
                <Separator Margin="0,8,0,8" />
                <Button Content="Run Proxy Lock Demo" Height="34" Margin="0,0,0,8" Click="ProxyDemoClick" />
                <Button Content="Export SVG Snapshot" Height="34" Click="ExportSvgClick" />
                <TextBlock Text="Operations Log" Margin="0,14,0,6" Foreground="#9CA3AF" />
                <ListBox Name="OperationsList" Height="220" />
            </StackPanel>
        </Border>

        <TabControl Grid.Column="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="1">
            <TabItem Header="Viewport">
                <Border Padding="10" Background="#F8FAFC">
                    <Canvas Name="ViewportCanvas" />
                </Border>
            </TabItem>
            <TabItem Header="SVG">
                <Grid Margin="10">
                    <TextBox Name="SvgTextBox"
                             FontFamily="Consolas"
                             FontSize="13"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,12,0,0"
                Padding="10"
                CornerRadius="8"
                Background="#1E293B"
                BorderBrush="#334155"
                BorderThickness="1">
            <TextBlock Name="StatusText" Foreground="#E2E8F0" Text="Ready." />
        </Border>
    </Grid>
</Window>
